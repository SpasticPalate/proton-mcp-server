{
  "name": "proton-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Proton Mail via Proton Bridge",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --outDir dist --clean --no-dts",
    "build:tsc": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "dotenv": "^16.4.0",
    "imapflow": "^1.0.171",
    "mailparser": "^3.7.0",
    "nodemailer": "^6.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
